# Runtime data
data/
!examples/**/data/

# Secrets
.env
.env.*
!.env.example

# Internal docs
PLANS.md

# Local config (keep .example only)
config/default.json

# Node
node_modules/

# Workspace: personal data files (keep .example.md only)
workspace/USER.md
workspace/MEMORY.md
workspace/GROUP_MEMORY.md

# Daily memory files (generated at runtime)
workspace/memory/*.md
!workspace/memory/.gitkeep

# Examples runtime copies (never commit)
examples/**/workspace/USER.md
examples/**/workspace/MEMORY.md
examples/**/workspace/GROUP_MEMORY.md
examples/**/workspace/memory/*.md
examples/**/config/default.json
examples/**/.env
examples/**/.env.*
!examples/**/.env.example

# Atomic write / lock artifacts
*.tmp
*.lock
*.processing
